# =============================================================================
# SpeakUp — Environment variables template
# =============================================================================
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.
# Each collaborator maintains their own .env locally.
# =============================================================================

# --- Django ---
SECRET_KEY=your-secret-key-here
DEBUG=True

# --- Database (SQL Server) ---
DB_NAME=speakup
DB_HOST=localhost
DB_PORT=1433
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# DB_DRIVER: name of the instalne.
#   Common values:
#     ODBC Driver 18 for SQL Server   ← most common (Docker / modern installs)
#     ODBC Driver 17 for SQL Se
DB_DRIVER=ODBC Driver 18 for SQL Server

# DB_EXTRA_PARAMS: semicolon-seeters.
#   Choose the line that matches YOUR environment and delete the others:
#
#   Docker / Linux (SQL Server
#     DB_EXTRA_PARAMS=Encrypt=yes;TrustServerCertificate=yes;
#
#   Windows native (Windows Integrated Authentication / SSPI):
#     DB_EXTRA_PARAMS=Encrypt=yes;TrustServerCertificate=yes;Trusted_Connection=yes;
#
#   Local dev with no encryption needed:
#     DB_EXTRA_PARAMS=Encrypt=n
DB_EXTRA_PARAMS=Encrypt=yes;TrustServerCertificate=yes;

# --- Email (for password reset) ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# For real SMTP, switch to smtp
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your@email.com
# EMAIL_HOST_PASSWORD=your-emai

# --- Anthropic AI (for interview sessions) ---
# Get your API key at https://console.anthropic.com
ANTHROPIC_API_KEY=your-api-key-here
